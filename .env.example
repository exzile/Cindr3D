# Optional updater configuration for an Orange Pi deployment.
# Copy to /etc/cindr3d-updater/updater.env on the device, not into the repo.

CINDR3D_REPO=exzile/Cindr3D
CINDR3D_UPDATER_HOST=127.0.0.1
CINDR3D_UPDATER_PORT=8787
CINDR3D_WEB_ROOT=/var/www/cindr3d
CINDR3D_STATE_FILE=/var/lib/cindr3d-updater/state.json
CINDR3D_TOKEN_FILE=/etc/cindr3d-updater/token
